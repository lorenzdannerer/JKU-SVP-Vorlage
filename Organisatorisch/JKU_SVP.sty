        \setlength{\parfillskip}{0pt plus 1fil}
        \raggedright 
        \singlespacing

        \vspace*{-1.5cm}
        \textcolor{SectionColor}{\rule{\linewidth}{1pt}}\par    % obere Linie
        \vspace{0pt}
        
        {\usekomafont{disposition}\large \textcolor{SectionColor}{\textit{Protokoll zu}}} \par
        \vspace{-2ex}
        
        \begin{center}
        
            % Haupttitel
            {\usekomafont{disposition}\Huge \textcolor{SectionColor}{\getSvpTitel}} \par
            \vspace{-8pt}
            \textcolor{SectionColor}{\rule{\linewidth}{1pt}}\par    % untere Linie
            \vspace{2ex}
            {\large \textit{Gruppe \getSvpGruppe: \getSvpMitglieder} \par}
            
            \vspace{8pt}
            
            am \getSvpTag
        \end{center}
        
        \vspace{2cm}
        
        % INHALTSVERZEICHNIS
        \setcounter{tocdepth}{1} 
        \deftocheading{toc}{} % Standard-Überschrift leeren

                \newcommand*{\myTOCdots}{\leaders\hbox{\tiny$\mkern 8mu .$}\hfill}

        \DeclareTOCStyleEntry[
          linefill=\myTOCdots,
          pagenumberbox=\mbox
        ]{tocline}{section}
    
        \noindent
        \begin{tcolorbox}[
            sharp corners,        
            colback=white,        
            colframe=SectionColor, 
            boxrule=1pt,        
            left=15pt,   right=15pt,   top=15pt,   bottom=20pt,           
            title={\textcolor{SectionColor}{Inhalt}},       
            detach title,
            before upper={{\usekomafont{disposition}\usekomafont{section}\tcbtitle}\par}
        ]
            \makeatletter
            \@starttoc{toc} % Gibt das Inhaltsverzeichnis aus
            \makeatother
        \end{tcolorbox}
        \par      
        \vfill 
                
        % UNTEN: LOGO & INFOS
        \hspace{8pt}\includegraphics[width=0.25\linewidth]{JKU_logo.pdf}
        \vfill
        \textbf{Schulversuchspraktikum Physik} \\
         Teil II \\[8pt]
        \getSvpSemester
                
        \end{titlepage}
         
