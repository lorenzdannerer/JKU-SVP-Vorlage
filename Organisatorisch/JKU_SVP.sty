% Logik zur Titel Aufspaltung
\cs_new_protected:Nn \_svp_split_titel:n
  {
    % Enthält der Titel einen Bindestrich?
    \tl_if_in:nnTF { #1 } { - }
      { 
        % JA
        \seq_set_split:Nnn \l_tmpa_seq { - } { #1 }
        \tl_gset:Nx \g_svp_kurztitel_tl { \seq_item:Nn \l_tmpa_seq { 1 } }
      }
      { 
        % NEIN
        \tl_gset:Nn \g_svp_kurztitel_tl { \color{red} ?? } 
      }

    \tl_trim_spaces:N \g_svp_kurztitel_tl
  }

% Variablen & Keys definieren
\keys_define:nn { jku / svp }
  {
    tag         .tl_set:N  = \g_svp_tag_tl,
    tag         .initial:n = { <kein Datum angegeben> },
    
    titel       .code:n = { 
                    \tl_gset:Nn \g_svp_titel_tl { #1 }    % Speichert den ganzen Titel
                    \_svp_split_titel:n { #1 }            % Führt die Aufspaltung aus
                  },
    
    gruppe      .tl_set:N  = \g_svp_gruppe_tl,
    gruppe      .initial:n = { <keine Gruppe angegeben> },
    
    mitglieder  .tl_set:N  = \g_svp_mitglieder_tl,
    mitglieder  .initial:n = { <kein Name angegeben> },
    
    semester    .tl_set:N  = \g_svp_semester_tl,
    semester    .initial:n = { <kein Semester angegeben> },
  }



% User-Interface Befehl
\NewDocumentCommand{\svpSetup}{m}
  { \keys_set:nn { jku / svp } { #1 } }

