% Interne Speichervariablen anlegen
\newcommand{\@praktikumstag}{}
\newcommand{\@versuchstitel}{}
\newcommand{\@versuchkurz}{}

% Der Text-Abschneider
\ExplSyntaxOn
\NewDocumentCommand{\SplitteTitel}{ m }
{
    \seq_set_split:Nnn \l_tmpa_seq { - } { #1 }
    \tl_set:Nx \l_tmpa_tl { \seq_item:Nn \l_tmpa_seq { 1 } }
    \tl_trim_spaces:N \l_tmpa_tl
    % Standard LaTeX \gdef verwenden, um Inkompatibilitäten zu vermeiden:
    \exp_args:NNx \gdef \@versuchkurz { \l_tmpa_tl } 
}
\ExplSyntaxOff

% User-Befehle 
\newcommand{\praktikumstag}[1]{\renewcommand{\@praktikumstag}{#1}}
\newcommand{\versuchstitel}[1]{%
    \renewcommand{\@versuchstitel}{#1}% 
    \SplitteTitel{#1}% 
}

% Kopfzeile
