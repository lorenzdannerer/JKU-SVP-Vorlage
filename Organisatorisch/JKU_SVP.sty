% %%%%%%%%%%%%%  BILD & GALERIE  %%%%%%%%%%%%%
\ExplSyntaxOn
 
% --- Variablen deklarieren ---
\bool_new:N \g_svp_in_galerie_bool
\int_new:N  \g_svp_gal_cols_int
\int_new:N  \g_svp_gal_count_int
\tl_new:N   \g_svp_gal_caption_tl
\tl_new:N   \g_svp_gal_label_tl
\tl_new:N   \g_svp_gal_autolabel_tl
 
\tl_new:N \l_svp_bild_caption_tl
\tl_new:N \l_svp_bild_label_tl
\tl_new:N \l_svp_bild_options_tl
\tl_new:N \l_svp_bild_width_tl
\box_new:N \l_svp_bild_box
 
% --- Variablen definieren ---
\keys_define:nn { svp / galerie }
  {
    cols      .int_set:N = \g_svp_gal_cols_int,
    cols      .initial:n = 2,
    caption   .tl_set:N  = \g_svp_gal_caption_tl,
    label     .tl_set:N  = \g_svp_gal_label_tl,
    autolabel .tl_set:N  = \g_svp_gal_autolabel_tl,
    autolabel .initial:n = none,
  }
 
\keys_define:nn { svp / bild }
  {
    width   .tl_set:N = \l_svp_bild_width_tl,
    caption .tl_set:N = \l_svp_bild_caption_tl,
    label   .tl_set:N = \l_svp_bild_label_tl,
    options .tl_set:N = \l_svp_bild_options_tl,
  }
 
% --- Hilfsbefehle ---
 
% Weißes Label-Kästchen ("A", "a" oder "1") oben links über dem Bild
\cs_new_protected:Nn \svp_insert_overlay:n
  {
    \llap
      {
        \makebox [ \box_wd:N \l_svp_bild_box ] [ l ]
          {
            \hspace{0.3em}
            \raisebox { \dim_eval:n { \box_ht:N \l_svp_bild_box - 1.2em } } [0pt][0pt]
              { \fcolorbox{black}{white}{ \sffamily\bfseries\small #1 } }
          }
      }
  }
 
% Bild einbinden – mit oder ohne zusätzliche includegraphics-Optionen
% #1 = width-Ausdruck, #2 = Dateiname
\cs_new_protected:Nn \svp_includegraphics:nn
  {
    \tl_if_empty:NTF \l_svp_bild_options_tl
      { 
        % Fall 1: Keine Extra-Optionen
        \includegraphics [ width = #1 ] { #2 } 
      }
      { 
        % Fall 2: Mit Optionen
        \use:x 
          { 
            \exp_not:N \includegraphics [ 
              \exp_not:V \l_svp_bild_options_tl , 
              width = #1 
            ] { #2 } 
          } 
      }
  }
 

% --- GALERIE Umgebung ---

\NewDocumentEnvironment { galerie } { O{} }
  {
    % Globale Galerievariablen zurücksetzen
    \tl_gclear:N  \g_svp_gal_caption_tl
    \tl_gclear:N  \g_svp_gal_label_tl
    \tl_gset:Nn   \g_svp_gal_autolabel_tl { none }
    \int_gset:Nn  \g_svp_gal_cols_int { 2 }
    \int_gzero:N  \g_svp_gal_count_int
    \bool_gset_true:N \g_svp_in_galerie_bool
 
    \keys_set:nn { svp / galerie } { #1 }
 
    \par\addvspace{\intextsep}
    \captionsetup{type=figure}
    \centering
  }
  {
    \par
    \tl_if_empty:NF \g_svp_gal_caption_tl
      {
        \captionof{figure}{ \g_svp_gal_caption_tl }
        \tl_if_empty:NF \g_svp_gal_label_tl { \label{ \g_svp_gal_label_tl } }
      }
    \par\addvspace{\intextsep}
    \bool_gset_false:N \g_svp_in_galerie_bool
  }
 
% --- \bild-BEFEHL ---
 
\NewDocumentCommand { \bild } { O{} m }
  {
    \mode_if_horizontal:T { \unskip }
    \group_begin:
 
    % Lokale Bildvariablen zurücksetzen und Keys laden
    \tl_clear:N \l_svp_bild_caption_tl
    \tl_clear:N \l_svp_bild_label_tl
    \tl_clear:N \l_svp_bild_options_tl

    \bool_if:NTF \g_svp_in_galerie_bool
      { \tl_set:Nn \l_svp_bild_width_tl { \linewidth } }
      { \tl_set:Nn \l_svp_bild_width_tl { 0.7\textwidth } }
    
    \keys_set:nn { svp / bild } { #1 }
 
    \bool_if:NTF \g_svp_in_galerie_bool
      {
        % Innerhalb der Galerie
        \int_gincr:N \g_svp_gal_count_int
 
        % Zeilenumbruch nach jeder vollen Spaltenreihe
        \int_compare:nNnT { \g_svp_gal_count_int } > { 1 }
          {
            \int_compare:nNnT
              { \int_mod:nn { \g_svp_gal_count_int - 1 } { \g_svp_gal_cols_int } } = { 0 }
              { \par\vspace{1em} }
          }
 
        % Horizontalen Abstand vor jedem Bild (außer dem ersten in der Reihe)
        \int_compare:nNnF
          { \int_mod:nn { \g_svp_gal_count_int - 1 } { \g_svp_gal_cols_int } } = { 0 }
          { \hspace{1em} }
 
        % Breite: gleichmäßige Aufteilung mit 1em Abstand zwischen Spalten
        \dim_set:Nn \l_tmpa_dim
          { ( \linewidth - 1em * ( \g_svp_gal_cols_int - 1 ) ) / \g_svp_gal_cols_int - 0.5pt }
 
        % Subfigure oder Minipage (je nachdem, ob die Galerie eine Gesamtcaption hat)
        \tl_if_empty:NTF \g_svp_gal_caption_tl
          { \begin{minipage}[t]{ \l_tmpa_dim } \captionsetup{type=figure} }
          { \begin{subfigure}[c]{ \l_tmpa_dim } }
 
          \centering
 
          % Bild in Box speichern (für Overlay-Berechnung)
          \hbox_set:Nn \l_svp_bild_box { \svp_includegraphics:nn { \l_svp_bild_width_tl } {#2} }
          \leavevmode
          \box_use:N \l_svp_bild_box
 
          % Autolabel-Overlay (A/a/1)
          \str_case:Vn \g_svp_gal_autolabel_tl
            {
              { A } { \svp_insert_overlay:n { \int_to_Alph:n { \g_svp_gal_count_int } } }
              { a } { \svp_insert_overlay:n { \int_to_alph:n { \g_svp_gal_count_int } } }
              { 1 } { \svp_insert_overlay:n { \int_to_arabic:n { \g_svp_gal_count_int } } }
            }
 
          % Einzelbild-Caption
          \tl_if_empty:NF \l_svp_bild_caption_tl
            {
              \caption{ \l_svp_bild_caption_tl }
              \tl_if_empty:NF \l_svp_bild_label_tl { \label{ \l_svp_bild_label_tl } }
            }
 
        \tl_if_empty:NTF \g_svp_gal_caption_tl
          { \end{minipage} }
          { \end{subfigure} }
 
        \ignorespaces
      }
      {
        % -- Einzelbild außerhalb der Galerie --
        \par\addvspace{\intextsep}
        \begin{center}
          \captionsetup{type=figure}
          \svp_includegraphics:nn { \l_svp_bild_width_tl } {#2}
          \tl_if_empty:NF \l_svp_bild_caption_tl
            {
              \caption{ \l_svp_bild_caption_tl }
              \tl_if_empty:NF \l_svp_bild_label_tl { \label{ \l_svp_bild_label_tl } }
            }
        \end{center}
        \par\addvspace{\intextsep}
      }
 
    \group_end:
  }

\ExplSyntaxOff
